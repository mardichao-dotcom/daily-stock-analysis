{# ──────────────────────────────────────────────────────────────────────────
   個股卡片 macro（S/A/分歧/單兵共用）
   with_chart=true → 顯示折疊式 K 線圖按鈕
────────────────────────────────────────────────────────────────────────── #}
{% macro stock_card(s, with_chart) %}
<div class="stock-card">

  <div class="stock-header">
    <span class="stock-name">{{ s.name }}</span>
    <span class="stock-code">{{ s.code }}</span>
    <span class="badge {{ 'badge-red' if s.grade == 'S級' else ('badge-yellow' if s.grade == 'A級' else 'badge-orange') }}">{{ s.grade }}</span>
    {% if s.is_leader %}<span class="badge badge-red">長子</span>{% endif %}
    {% if s.break_60d %}<span class="badge badge-green">突破60日高</span>{% endif %}
    {% if s.is_gap_up  %}<span class="badge badge-teal">跳空開高</span>{% endif %}
    {% if s.vol_ratio >= 2.0 %}<span class="badge badge-yellow">爆量{{ '%.2f'|format(s.vol_ratio) }}x</span>{% endif %}
    {% for tag in s.tags %}<span class="badge badge-orange">{{ tag }}</span>{% endfor %}
  </div>

  <div class="price-row">
    <div class="pitem">
      <span class="plabel">收盤</span>
      <span class="pval {{ 'up' if s.change_pct > 0 else ('dn' if s.change_pct < 0 else 'neutral') }}">
        {{ s.close|int }} ({{ '%+.2f'|format(s.change_pct) }}%)
      </span>
    </div>
    <div class="pitem">
      <span class="plabel">量比</span>
      <span class="pval {{ 'up' if s.vol_ratio >= 1.5 else '' }}">{{ '%.2f'|format(s.vol_ratio) }}x</span>
    </div>
    <div class="pitem"><span class="plabel">K棒</span><span class="pval">{{ s.k_pattern }}</span></div>
    {% if s.etf_count > 0 %}
    <div class="pitem">
      <span class="plabel">ETF籌碼</span>
      <span class="pval" style="color:var(--teal)">
        {{ s.etf_count }}檔共識{{ '連續' if s.is_continuous else '' }}加碼
      </span>
    </div>
    {% endif %}
  </div>

  <div class="score-line">
    <span>積分</span>
    <span class="score-num">{{ s.score }}</span>
    <button class="score-toggle" onclick="toggleBreakdown(this, 'bd-{{ s.chart_id }}')">▼ 查看計分明細</button>
  </div>
  <div class="score-breakdown" id="bd-{{ s.chart_id }}">
    {% for item in s.breakdown %}
    <span class="{{ 'sb-pos' if item['分數'] > 0 else 'sb-neg' }}">
      {{ '+%d'|format(item['分數']) if item['分數'] > 0 else item['分數'] }}　{{ item['項目'] }}
    </span><br>
    {% endfor %}
  </div>

  <div class="desc">{{ s.judgment }}</div>

  {# 關鍵價預留坑（階段 6 填入） #}
  {% if s.key_prices %}
  <div class="keyprice-block">{{ s.key_prices }}</div>
  {% endif %}

  {# 折疊式 K 線圖 #}
  {% if with_chart and s.has_chart %}
  <div class="chart-toggle">
    <button class="chart-btn"
            onclick="toggleChart(this, '{{ s.chart_id }}', '{{ prefix }}{{ s.chart_path }}')">
      ▼ 展開 K 線圖
    </button>
    <div id="{{ s.chart_id }}" class="chart-container"></div>
  </div>
  {% endif %}

</div>
{% endmacro %}

<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>台股動能作戰儀表板 ｜ {{ data_date }}</title>
<link rel="icon" href="{{ prefix }}favicon.ico">
<link rel="stylesheet" href="{{ prefix }}assets/style.css?v=1">
</head>
<body>

{# ── 區塊 0：頁首 ── #}
<div class="header">
  <h1>🧭 台股右側動能作戰儀表板</h1>
  <div class="meta">
    資料日期：{{ data_date_fmt }} ｜ 對應 {{ next_date_fmt }} 開盤 ｜
    籌碼基準：{{ 籌碼基準 }}
  </div>
  <div class="index-bar">
    <div class="index-item">
      <span class="label">啟動族群</span>
      <span class="val">{{ 啟動族群_text }}</span>
    </div>
    <div class="index-item">
      <span class="label">S/A 級個股</span>
      <span class="val" style="color:var(--green)">{{ sa_count }} 檔</span>
    </div>
    <div class="index-item">
      <span class="label">資料完整度</span>
      <span class="val" style="color:var(--green)">{{ total_stocks }}/{{ total_stocks }}</span>
    </div>
  </div>
</div>

{# ── 區塊 1：大盤狀態速覽 ── #}
<div class="section">
  <div class="section-header market-header">📊 大盤狀態速覽</div>
  <div class="section-body">
    <div class="group">
      <div class="desc">
        啟動族群：<strong>{{ 啟動族群_text }}</strong>。
        警報個股 {{ alert_count }} 檔，黑名單 {{ black_count }} 檔。
        {%- if not 啟動族群 %}今日無族群整體發動，為個股分散行情。{%- endif %}
      </div>
      <div class="empty-state" style="margin-top:8px;text-align:left;font-style:normal;font-size:12px">
        📌 大盤指數快照（加權/櫃買/跌停數）— 待階段 4 接入 TV 即時資料
      </div>
    </div>
  </div>
</div>

{# ── 區塊 2：國際領先指標 ── #}
<div class="section">
  <div class="section-header global-header">🌏 國際領先指標摘要</div>
  <div class="section-body">
    <div class="group">
      <div class="empty-state" style="text-align:left;font-style:normal;font-size:12px">
        📌 國際族群長子表現表格 — 待階段 4 接入 TV 即時資料（NVDA/TSM/ASML...）
      </div>
    </div>
  </div>
</div>

{# ── 區塊 3：S 級戰區 ── #}
<div class="section">
  <div class="section-header s-header">🔴 S 級戰區：強勢共振發動</div>
  <div class="section-body">
    {% if s_stocks %}
      {% for s in s_stocks %}
      <div class="group">{{ stock_card(s, with_chart=true) }}</div>
      {% endfor %}
    {% else %}
      <div class="empty-state">今日無 S 級個股</div>
    {% endif %}
  </div>
</div>

{# ── 區塊 4：A 級戰區 ── #}
<div class="section">
  <div class="section-header a-header">🟡 A 級戰區：資金潛伏觀察</div>
  <div class="section-body">
    {% if a_stocks %}
      {% for s in a_stocks %}
      <div class="group">{{ stock_card(s, with_chart=true) }}</div>
      {% endfor %}
    {% else %}
      <div class="empty-state">今日無 A 級個股</div>
    {% endif %}
  </div>
</div>

{# ── 區塊 5：ETF 經理人分歧區 ── #}
<div class="section">
  <div class="section-header div-header">⚠️ ETF 經理人分歧區</div>
  <div class="section-body">
    {% if div_stocks %}
      {% for s in div_stocks %}
      <div class="group">{{ stock_card(s, with_chart=false) }}</div>
      {% endfor %}
    {% else %}
      <div class="empty-state">今日無 ETF 經理人分歧訊號</div>
    {% endif %}
  </div>
</div>

{# ── 區塊 6：警報區 ── #}
<div class="section">
  <div class="section-header warn-header">🟢 警報區（具備部分訊號）</div>
  <div class="section-body">
    {% if alert_stocks %}
      <div class="group">
        {% for s in alert_stocks %}
        <div class="stock-card">
          <div class="stock-header">
            <span class="stock-name">{{ s.name }}</span>
            <span class="stock-code">{{ s.code }}</span>
            <span class="badge badge-gray">警報</span>
            {% for tag in s.tags %}<span class="badge badge-orange">{{ tag }}</span>{% endfor %}
          </div>
          <div class="price-row">
            <div class="pitem">
              <span class="plabel">收盤</span>
              <span class="pval {{ 'up' if s.change_pct > 0 else ('dn' if s.change_pct < 0 else 'neutral') }}">
                {{ s.close|int }} ({{ '%+.2f'|format(s.change_pct) }}%)
              </span>
            </div>
            <div class="pitem"><span class="plabel">量比</span><span class="pval">{{ '%.2f'|format(s.vol_ratio) }}x</span></div>
            <div class="pitem"><span class="plabel">板塊</span><span class="pval" style="color:var(--muted)">{{ s.sector }}</span></div>
            <div class="pitem"><span class="plabel">分數</span><span class="pval">{{ s.score }}</span></div>
          </div>
        </div>
        {% endfor %}
      </div>
    {% else %}
      <div class="empty-state">今日無警報個股</div>
    {% endif %}
  </div>
</div>

{# ── 區塊 7：黑名單 ── #}
<div class="section">
  <div class="section-header black-header">⛔ 黑名單（技術或籌碼面惡化）</div>
  <div class="section-body">
    {% if black_stocks %}
      <div class="group">
        {% for s in black_stocks %}
        <div class="stock-card">
          <div class="stock-header">
            <span class="stock-name">{{ s.name }}</span>
            <span class="stock-code">{{ s.code }}</span>
            <span class="badge badge-gray">黑名單</span>
            {% for tag in s.tags %}<span class="badge badge-red">{{ tag }}</span>{% endfor %}
          </div>
          <div class="price-row">
            <div class="pitem">
              <span class="plabel">收盤</span>
              <span class="pval {{ 'up' if s.change_pct > 0 else ('dn' if s.change_pct < 0 else 'neutral') }}">
                {{ s.close|int }} ({{ '%+.2f'|format(s.change_pct) }}%)
              </span>
            </div>
            <div class="pitem"><span class="plabel">量比</span><span class="pval">{{ '%.2f'|format(s.vol_ratio) }}x</span></div>
            <div class="pitem"><span class="plabel">板塊</span><span class="pval" style="color:var(--muted)">{{ s.sector }}</span></div>
            <div class="pitem"><span class="plabel">分數</span><span class="pval">{{ s.score }}</span></div>
          </div>
          {% if s.neg_items %}
          <div class="desc" style="margin-top:4px">負面訊號：{{ s.neg_items | join('、') }}</div>
          {% endif %}
        </div>
        {% endfor %}
      </div>
    {% else %}
      <div class="empty-state">今日無黑名單個股</div>
    {% endif %}
  </div>
</div>

{# ── 區塊 8：強勢單兵作戰 ── #}
<div class="section">
  <div class="section-header lone-header">🚨 強勢單兵作戰（族群走弱但個股強）</div>
  <div class="section-body">
    {% if lone_stocks %}
      {% for s in lone_stocks %}
      <div class="group">{{ stock_card(s, with_chart=false) }}</div>
      {% endfor %}
    {% else %}
      <div class="empty-state">今日無單兵作戰個股</div>
    {% endif %}
  </div>
</div>

{# ── 區塊 9：全球同步／獨秀／拖累 ── #}
<div class="section">
  <div class="section-header global-header">🌐 全球同步 / 獨秀 / 拖累</div>
  <div class="section-body">
    <div class="group">
      <div class="empty-state" style="text-align:left;font-style:normal;font-size:12px">
        📌 台灣 vs 國際同族群對比表格 — 待階段 4 接入 TV 即時資料
      </div>
    </div>
  </div>
</div>

{# ── 區塊 10：訊號狀態總覽 ── #}
<div class="section">
  <div class="section-header sig-header">📋 訊號狀態總覽（T+N 追蹤）</div>
  <div class="section-body">
    <div class="group">
      {% if signal_tracking %}
      <table>
        <thead>
          <tr><th>個股</th><th>代號</th><th>首次發出日</th><th>目前分級</th><th>持有天數</th></tr>
        </thead>
        <tbody>
          {% for row in signal_tracking %}
          <tr>
            <td>{{ row.name }}</td>
            <td>{{ row.code }}</td>
            <td>{{ row.first_date }}</td>
            <td><span class="badge {{ 'badge-red' if row.grade == 'S級' else 'badge-yellow' }}">{{ row.grade }}</span></td>
            <td>{{ row.days }} 天</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% else %}
        <div class="empty-state">尚無追蹤中訊號</div>
      {% endif %}
    </div>
  </div>
</div>

{# ── 頁尾 ── #}
<div class="footer">
  資料來源：本機 SQLite（kline.db / etf_operations.db）｜
  籌碼：ETF Edge 近 7 日累計 ｜
  本儀表板僅供輔助判讀，不構成投資建議。<br>
  <a href="archives/index.html">📁 歷史存檔</a> ｜
  產出時間：{{ 產出時間 }}
</div>

{# ── JavaScript ── #}
<script src="{{ prefix }}assets/lightweight-charts.js?v=5.2.0"></script>
<script src="{{ prefix }}assets/chart.js?v=4"></script>
<script>
async function toggleChart(btn, chartId, dataPath) {
  const container = document.getElementById(chartId);
  const isOpen = container.style.display !== 'none';
  if (isOpen) {
    container.style.display = 'none';
    btn.textContent = '▼ 展開 K 線圖';
  } else {
    container.style.display = 'block';
    btn.textContent = '▲ 收合 K 線圖';
    if (!container.dataset.loaded) {
      container.dataset.loaded = '1';
      container.innerHTML = '<div class="chart-loading">載入中...</div>';
      try {
        const resp = await fetch(dataPath);
        if (!resp.ok) throw new Error('HTTP ' + resp.status);
        const data = await resp.json();
        container.innerHTML = '';
        renderChart(chartId, data);
      } catch (e) {
        container.innerHTML =
          '<div class="chart-loading" style="color:#ff4d4d">載入失敗：' + e.message + '</div>';
      }
    }
  }
}

function toggleBreakdown(btn, bdId) {
  const bd = document.getElementById(bdId);
  const isOpen = bd.classList.contains('open');
  bd.classList.toggle('open', !isOpen);
  btn.textContent = isOpen ? '▼ 查看計分明細' : '▲ 收合計分明細';
}
</script>

</body>
</html>
